# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Database files (never commit real data) ───────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak
*.sqlite
*.sqlite3

# ── Environment / secrets ────────────────────────────────────
.env
.env.local
.env.production
secrets.json
config.local.py

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Hidden/temp files ────────────────────────────────────────
.fuse_hidden*
*.tmp
*.temp
*.swp
*.swo

# ── Node / frontend ──────────────────────────────────────────
node_modules/
dist/
.next/
build/

# ── Word/Office temp files ───────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx

# ── Deploy artifacts (keep scripts, not generated files) ─────
deploy-scripts/
*.docx
